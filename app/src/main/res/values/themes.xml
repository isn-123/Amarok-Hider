<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Amarok" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:windowBackground">@color/midnight_background</item>
        <item name="colorPrimary">@color/midnight_primary</item>
        <item name="colorOnPrimary">@color/midnight_on_primary</item>
        <item name="colorSecondary">@color/midnight_secondary</item>
        <item name="colorOnSecondary">@color/midnight_on_secondary</item>
        <item name="colorSurface">@color/midnight_surface</item>
        <item name="colorOnSurface">@color/midnight_on_surface</item>
        <item name="colorSurfaceVariant">@color/midnight_surface_container</item>
        <item name="colorOnSurfaceVariant">@color/midnight_on_surface_variant</item>
        <item name="colorOutline">@color/midnight_outline</item>
        <item name="colorOutlineVariant">@color/midnight_outline_variant</item>
        <item name="preferenceTheme">@style/Theme.Amarok.Preference</item>
    </style>

    <style name="Theme.Amarok.Transparent" parent="Theme.Amarok">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.Calculator" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/calendar_bg_light</item>
        <item name="android:navigationBarColor">@color/calendar_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.Amarok.Preference" parent="@style/PreferenceThemeOverlay.Rikka.Material3">
        <item name="android:tint">?attr/colorOnBackground</item>
    </style>

</resources>