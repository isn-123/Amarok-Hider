<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button"
        android:id="@+id/hidefiles_bt_add_folder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="12dp"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:text="@string/add_hide_files"
        android:onClick="addHideFolder"
        app:backgroundTint="@color/midnight_secondary"
        android:textColor="@color/midnight_on_secondary"
        app:iconTint="@color/midnight_on_secondary"
        app:icon="@drawable/ic_add"
        app:cornerRadius="12dp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:text="@string/folder_selector_hints"
        android:textColor="@color/midnight_on_surface_variant"
        android:textSize="11sp" />

</LinearLayout>